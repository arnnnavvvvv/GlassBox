# No real keys, ever -- copy this to .env and fill in locally.

# Monad testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_TX_URL=https://testnet.monadexplorer.com/tx

# contracts/ -- the wallet that deploys GlassBox.sol
DEPLOYER_PRIVATE_KEY=

# backend/ -- the wallet that submits commitDecision()/registerPolicy() txs.
# Lives only in the backend's environment -- never on the machine running
# the agent pipeline, never in the repo.
BACKEND_WALLET_PRIVATE_KEY=
GLASSBOX_DEPLOYMENT_NETWORK=monadTestnet

# agents/ -- LLM calls for the trading and risk agent nodes
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GLASSBOX_BACKEND_URL=http://localhost:8000

# webapp/ has its own .env.local (see webapp/.env.example) since Next.js
# requires the NEXT_PUBLIC_ prefix for browser-visible vars.
